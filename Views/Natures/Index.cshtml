@model TeamAceProject.Models.ViewModels.Natures.NatureListViewModel
@{
    ViewData["Title"] = "Natures";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">natures</h1>
        <p class="text-muted mb-0">@Model.Natures.Count natures</p>
    </div>
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="search by name" />
        <button class="btn btn-primary" type="submit">search</button>
    </form>
</div>

<div class="row g-3">
    @foreach (var nature in Model.Natures)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm rounded-4">
                <div class="card-body d-flex flex-column">
                    <h2 class="h6 mb-2">@nature.DisplayName</h2>
                    @if (nature.IsNeutral)
                    {
                        <p class="small text-muted mb-3">neutral</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            @if (nature.IncreasedStat != null)
                            {
                                <div class="small">
                                    <span class="text-success fw-semibold">↑</span> @nature.IncreasedStat
                                </div>
                            }
                            @if (nature.DecreasedStat != null)
                            {
                                <div class="small">
                                    <span class="text-danger fw-semibold">↓</span> @nature.DecreasedStat
                                </div>
                            }
                        </div>
                    }
                    <a class="btn btn-outline-primary mt-auto w-100"
                       asp-action="Details" asp-route-name="@nature.Name">details</a>
                </div>
            </div>
        </div>
    }
</div>
