@model TeamAceProject.Models.ViewModels.Posts.PostDetailsViewModel
@using TeamAceProject.Models.Enums
@{
    ViewData["Title"] = "Post";
}

<div class="card shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="small text-muted">@Model.Username · @Model.CreatedAt.ToLocalTime().ToString("g")</div>
        <h1 class="h3 mt-2">@Model.TeamName</h1>
        <p>@Model.Caption</p>
        <div class="d-flex flex-wrap gap-2">
            <form asp-action="React" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id" />
                <input type="hidden" name="type" value="@ReactionType.Like" />
                <button type="submit" class="btn btn-outline-success">👍 @Model.LikeCount</button>
            </form>
            <form asp-action="React" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id" />
                <input type="hidden" name="type" value="@ReactionType.Dislike" />
                <button type="submit" class="btn btn-outline-danger">👎 @Model.DislikeCount</button>
            </form>
            <a class="btn btn-outline-primary" asp-controller="Teams" asp-action="Details" asp-route-id="@Model.TeamId">view team</a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">add comment</h2>
                <form asp-action="AddComment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <textarea name="body" class="form-control mb-3" rows="4" placeholder="say something about the team"></textarea>
                    <button type="submit" class="btn btn-primary">comment</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">comments</h2>
                @if (Model.Comments.Count == 0)
                {
                    <p class="text-muted mb-0">No comments yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="border rounded-4 p-3">
                                <div class="small text-muted">@comment.Username · @comment.CreatedAt.ToLocalTime().ToString("g")</div>
                                <div class="mt-2">@comment.Body</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
