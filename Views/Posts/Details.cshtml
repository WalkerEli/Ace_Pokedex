@model TeamAceProject.Models.ViewModels.Posts.PostDetailsViewModel
@using TeamAceProject.Models.Enums
@using System.Security.Claims
@{
    ViewData["Title"] = "Post";
    Guid? currentUserId = Guid.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var _uid) ? _uid : (Guid?)null;
    bool isOwner = currentUserId.HasValue && currentUserId.Value == Model.UserId;
}

<div class="card shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="small text-muted">
            <a class="text-muted text-decoration-none fw-semibold"
               asp-controller="Users" asp-action="Details" asp-route-id="@Model.UserId">@Model.Username</a>
            · @Model.CreatedAt.ToLocalTime().ToString("g")
        </div>
        <h1 class="h3 mt-2">@Model.TeamName</h1>
        <p>@Model.Caption</p>
        <div class="d-flex flex-wrap gap-2">
            <button id="btn-like" class="btn btn-outline-success" data-post-id="@Model.Id" data-type="@((int)ReactionType.Like)">
                👍 <span id="like-count">@Model.LikeCount</span>
            </button>
            <button id="btn-dislike" class="btn btn-outline-danger" data-post-id="@Model.Id" data-type="@((int)ReactionType.Dislike)">
                👎 <span id="dislike-count">@Model.DislikeCount</span>
            </button>
            @if (isOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">edit post</a>
                <form asp-action="Delete" method="post" class="d-inline"
                      data-confirm="Delete this post? This cannot be undone.">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger">delete post</button>
                </form>
            }
        </div>
    </div>
</div>

@if (Model.Members.Count > 0)
{
    <div class="card shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <h2 class="h4 mb-3">team members</h2>
            <div class="vstack gap-3">
                @foreach (var member in Model.Members)
                {
                    <div class="border rounded-4 p-3">
                        <div class="d-flex gap-3 align-items-center">
                            @if (!string.IsNullOrWhiteSpace(member.PokemonSpriteUrl))
                            {
                                <img src="@member.PokemonSpriteUrl" alt="@member.PokemonName"
                                     style="width:80px;height:80px;image-rendering:pixelated;flex-shrink:0;" />
                            }
                            <div>
                                <div class="small text-muted">slot @member.SlotIndex</div>
                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                    <h3 class="h5 mb-0">@member.PokemonName</h3>
                                    @foreach (var type in member.Types)
                                    {
                                        <span class="badge pokemon-type-@type.ToLower()">@type</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(member.AbilityName))
                                {
                                    <div><strong>ability:</strong> @member.AbilityName</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(member.NatureName))
                                {
                                    <div><strong>nature:</strong> @member.NatureName</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(member.HeldItemName))
                                {
                                    <div><strong>held item:</strong> @member.HeldItemName</div>
                                }
                                @if (member.Moves.Count > 0)
                                {
                                    <div><strong>moves:</strong> @string.Join(", ", member.Moves)</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4">
    @if (User.Identity?.IsAuthenticated == true)
    {
    <div class="col-lg-5">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">add comment</h2>
                <form id="comment-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <textarea id="comment-body" name="body" class="form-control mb-3" rows="4"
                              placeholder="say something about the team"
                              data-maxlength="1000"></textarea>
                    <button type="submit" class="btn btn-primary">comment</button>
                    <div id="comment-error" class="text-danger mt-2 d-none"></div>
                </form>
            </div>
        </div>
    </div>
    }
    <div class="col-lg-7">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">comments</h2>
                <div id="comment-list">
                    @if (Model.Comments.Count == 0)
                    {
                        <p id="no-comments" class="text-muted mb-0">No comments yet.</p>
                    }
                    else
                    {
                        <div class="vstack gap-3">
                            @foreach (var comment in Model.Comments)
                            {
                                bool isCommentOwner = currentUserId.HasValue && currentUserId.Value == comment.UserId;
                                <div class="border rounded-4 p-3" data-comment-id="@comment.Id">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="small text-muted">
                                        <a class="text-muted text-decoration-none fw-semibold"
                                           asp-controller="Users" asp-action="Details" asp-route-id="@comment.UserId">@comment.Username</a>
                                        · @comment.CreatedAt.ToLocalTime().ToString("g")
                                    </div>
                                        @if (isCommentOwner)
                                        {
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-link btn-sm p-0 text-secondary btn-edit-comment">edit</button>
                                                <button class="btn btn-link btn-sm p-0 text-danger btn-delete-comment">delete</button>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-2 comment-body">@comment.Body</div>
                                    @if (isCommentOwner)
                                    {
                                        <div class="comment-edit-form d-none mt-2">
                                            <textarea class="form-control mb-2 edit-textarea" rows="3">@comment.Body</textarea>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-primary btn-sm btn-save-comment">save</button>
                                                <button class="btn btn-outline-secondary btn-sm btn-cancel-edit">cancel</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script defer type="module" src="~/js/post.js"></script>
}
