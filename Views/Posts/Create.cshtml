@model TeamAceProject.Models.Entities.Post
@{
    ViewData["Title"] = "Create Post";
}

<h1 class="mb-4">create post</h1>

<div class="card shadow-sm rounded-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />

            <div class="mb-3">
                <label asp-for="TeamId" class="form-label">team id</label>
                <input asp-for="TeamId" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Caption" class="form-label"></label>
                <textarea asp-for="Caption" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Caption" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">publish</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
