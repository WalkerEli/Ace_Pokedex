@model TeamAceProject.Models.Entities.Post
@{
    ViewData["Title"] = "Create Post";
}

<h1 class="mb-4">create post</h1>

<div class="card shadow-sm rounded-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validation-summary"></div>

            <div class="mb-3">
                <label class="form-label">team</label>
                <select id="team-select" name="TeamId" class="form-select" required data-preselected="@Model.TeamId">
                    <option value="">loading your teams...</option>
                </select>
                <span asp-validation-for="TeamId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Caption" class="form-label"></label>
                <textarea asp-for="Caption" class="form-control" rows="4"
                          placeholder="share your team strategy..."
                          data-maxlength="1000"></textarea>
                <span asp-validation-for="Caption" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">publish</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
<script defer type="module" src="~/js/post.js"></script>
}
