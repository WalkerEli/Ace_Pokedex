@model List<TeamAceProject.Models.ViewModels.Teams.TeamListItemViewModel>
@{
    ViewData["Title"] = "Teams";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Teams</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">create team</a>
</div>

<div class="row g-3">
    @foreach (var team in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="small text-muted">by @team.Username</div>
                    <h2 class="h5 mt-2">@team.Name</h2>
                    <p class="mb-2">@team.MemberCount / 6 members</p>
                    <span class="badge @(team.IsPublic ? "text-bg-success" : "text-bg-secondary")">@(team.IsPublic ? "public" : "private")</span>
                    <div class="mt-3">
                        <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@team.Id">open</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
