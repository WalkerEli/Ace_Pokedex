@model TeamAceProject.Models.ViewModels.Teams.TeamDetailsViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Name;
    Guid? currentUserId = Guid.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var _uid) ? _uid : (Guid?)null;
    bool isOwner = currentUserId.HasValue && currentUserId.Value == Model.UserId;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">@Model.Name</h1>
        <p class="text-muted mb-1">owner: @Model.Username</p>
        <span class="badge @(Model.IsPublic ? "text-bg-success" : "text-bg-secondary")">@(Model.IsPublic ? "public" : "private")</span>
    </div>
    <div class="d-flex gap-2">
        @if (isOwner)
        {
            <a class="btn btn-outline-secondary" asp-controller="Posts" asp-action="Create" asp-route-teamId="@Model.Id">create post</a>
        }
        <div id="share-target" class="d-flex gap-2"></div>
        @if (isOwner)
        {
            <form asp-action="Delete" method="post"
                  data-confirm="Delete this team and all its members? This cannot be undone.">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">delete team</button>
            </form>
        }
    </div>
</div>

@if (TempData["TeamSuccess"] != null)
{
    <div class="alert alert-success">@TempData["TeamSuccess"]</div>
}
@if (TempData["TeamError"] != null)
{
    <div class="alert alert-danger">@TempData["TeamError"]</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4 mb-3">current members</h2>
                @if (Model.Members.Count == 0)
                {
                    <p class="text-muted mb-0">No pokemon have been added yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var member in Model.Members)
                        {
                            var apiName = member.PokemonName.ToLowerInvariant().Replace(" ", "-");
                            <div class="border rounded-4 p-3">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div class="d-flex gap-3 align-items-center">
                                        @if (!string.IsNullOrWhiteSpace(member.PokemonSpriteUrl))
                                        {
                                            <img src="@member.PokemonSpriteUrl" alt="@member.PokemonName" class="team-sprite" />
                                        }
                                        <div>
                                            <div class="small text-muted">slot @member.SlotIndex</div>
                                            <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                                                <h3 class="h5 mb-0">@member.PokemonName</h3>
                                                @foreach (var type in member.Types)
                                                {
                                                    <span class="badge pokemon-type-@type.ToLower()">@type</span>
                                                }
                                            </div>
                                            <div><strong>ability:</strong> @(string.IsNullOrWhiteSpace(member.AbilityName) ? "-" : member.AbilityName)</div>
                                            <div><strong>nature:</strong> @(string.IsNullOrWhiteSpace(member.NatureName) ? "-" : member.NatureName)</div>
                                            <div><strong>held item:</strong> @(string.IsNullOrWhiteSpace(member.HeldItemName) ? "-" : member.HeldItemName)</div>
                                            <div><strong>moves:</strong> @(member.Moves.Count == 0 ? "-" : string.Join(", ", member.Moves))</div>
                                        </div>
                                    </div>
                                    @if (isOwner)
                                    {
                                        <div class="d-flex gap-1">
                                            <button type="button" class="btn btn-sm btn-outline-secondary btn-edit-member"
                                                    data-member-id="@member.Id"
                                                    data-api-name="@apiName"
                                                    data-ability="@(member.AbilityName ?? "")">
                                                edit
                                            </button>
                                            <form asp-action="RemoveMember" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="teamId" value="@Model.Id" />
                                                <input type="hidden" name="teamMemberId" value="@member.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">remove</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                                @if (isOwner)
                                {
                                    <div class="edit-member-panel d-none mt-3 pt-3 border-top" id="edit-panel-@member.Id">
                                        <form asp-action="EditMember" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="TeamMemberId" value="@member.Id" />
                                            <input type="hidden" name="TeamId" value="@Model.Id" />
                                            <div class="row g-2 mb-2">
                                                <div class="col-md-6">
                                                    <label class="form-label small fw-semibold">pokemon</label>
                                                    <input type="text" name="PokemonName" class="form-control form-control-sm edit-pokemon-input"
                                                           value="@member.PokemonName" autocomplete="off" list="pokemon-datalist" />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small fw-semibold">ability</label>
                                                    <select name="AbilityName" class="form-select form-select-sm edit-ability-select">
                                                        <option value="">-- loading --</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small fw-semibold">nature</label>
                                                    <input type="text" name="NatureName" class="form-control form-control-sm"
                                                           value="@member.NatureName" autocomplete="off" list="nature-datalist" />
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small fw-semibold">held item</label>
                                                    <input type="text" name="HeldItemName" class="form-control form-control-sm"
                                                           value="@member.HeldItemName" autocomplete="off" list="held-item-datalist" />
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label small fw-semibold">moves</label>
                                                <div class="row g-1">
                                                    @for (int i = 1; i <= 4; i++)
                                                    {
                                                        <div class="col-6">
                                                            <input type="text" name="Move@(i)" class="form-control form-control-sm edit-move-input"
                                                                   value="@(member.Moves.Count >= i ? member.Moves[i - 1] : "")"
                                                                   autocomplete="off" list="edit-moves-@member.Id"
                                                                   placeholder="move @i" disabled />
                                                        </div>
                                                    }
                                                    <datalist id="edit-moves-@member.Id"></datalist>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-primary btn-sm">save changes</button>
                                                <button type="button" class="btn btn-outline-secondary btn-sm btn-cancel-edit-member">cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @if (isOwner)
    {
    <div class="col-lg-5">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">add pokemon</h2>
                <form asp-action="AddMember" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TeamId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">pokemon</label>
                        <input type="text" name="PokemonName" id="pokemon-input"
                               class="form-control" placeholder="loading pokemon..."
                               autocomplete="off" list="pokemon-datalist" />
                        <datalist id="pokemon-datalist"></datalist>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ability</label>
                        <select name="AbilityName" id="ability-select" class="form-select">
                            <option value="">-- select a pokemon first --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">nature</label>
                        <input type="text" name="NatureName" class="form-control"
                               placeholder="type to search nature..." autocomplete="off"
                               list="nature-datalist" />
                        <datalist id="nature-datalist">
                            <option>Hardy</option><option>Lonely</option><option>Brave</option>
                            <option>Adamant</option><option>Naughty</option><option>Bold</option>
                            <option>Docile</option><option>Relaxed</option><option>Impish</option>
                            <option>Lax</option><option>Timid</option><option>Hasty</option>
                            <option>Serious</option><option>Jolly</option><option>Naive</option>
                            <option>Modest</option><option>Mild</option><option>Quiet</option>
                            <option>Bashful</option><option>Rash</option><option>Calm</option>
                            <option>Gentle</option><option>Sassy</option><option>Careful</option>
                            <option>Quirky</option>
                        </datalist>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">held item</label>
                        <input type="text" name="HeldItemName" id="held-item-input"
                               class="form-control" placeholder="loading items..."
                               autocomplete="off" list="held-item-datalist" />
                        <datalist id="held-item-datalist"></datalist>
                    </div>

                    <div class="mb-2"><strong>moves</strong></div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="text" name="Move1" id="move-input-1" class="form-control"
                                   placeholder="select a pokemon first" autocomplete="off"
                                   list="move-datalist-1" disabled />
                            <datalist id="move-datalist-1"></datalist>
                        </div>
                        <div class="col-6">
                            <input type="text" name="Move2" id="move-input-2" class="form-control"
                                   placeholder="select a pokemon first" autocomplete="off"
                                   list="move-datalist-2" disabled />
                            <datalist id="move-datalist-2"></datalist>
                        </div>
                        <div class="col-6">
                            <input type="text" name="Move3" id="move-input-3" class="form-control"
                                   placeholder="select a pokemon first" autocomplete="off"
                                   list="move-datalist-3" disabled />
                            <datalist id="move-datalist-3"></datalist>
                        </div>
                        <div class="col-6">
                            <input type="text" name="Move4" id="move-input-4" class="form-control"
                                   placeholder="select a pokemon first" autocomplete="off"
                                   list="move-datalist-4" disabled />
                            <datalist id="move-datalist-4"></datalist>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">add to team</button>
                </form>
            </div>
        </div>
    </div>
    }
</div>

@section Scripts {
<script defer type="module" src="~/js/teamDetails.js"></script>
}
