@model TeamAceProject.Models.ViewModels.Items.ItemListPageViewModel
@{
    ViewData["Title"] = "Held Items";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">held items</h1>
        <p class="text-muted mb-0">@Model.TotalCount items that can be held by a Pokemon</p>
    </div>
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="search by name" />
        <button class="btn btn-primary" type="submit">search</button>
    </form>
</div>

<div class="row g-3 mb-4">
    @foreach (var item in Model.Items)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm rounded-4 text-center">
                <div class="card-body d-flex flex-column align-items-center">
                    @if (!string.IsNullOrWhiteSpace(item.SpriteUrl))
                    {
                        <img src="@item.SpriteUrl" alt="@item.DisplayName"
                             style="width:48px;height:48px;image-rendering:pixelated;"
                             onerror="this.style.visibility='hidden'" />
                    }
                    <h2 class="h6 mt-2 mb-3">@item.DisplayName</h2>
                    <a class="btn btn-outline-primary mt-auto w-100"
                       asp-action="Details" asp-route-name="@item.Name">details</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center">
    <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber - 1)"
       asp-route-pageSize="@Model.PageSize"
       asp-route-query="@Model.Query">previous</a>

    <span>page @Model.PageNumber</span>

    <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber + 1)"
       asp-route-pageSize="@Model.PageSize"
       asp-route-query="@Model.Query">next</a>
</div>
