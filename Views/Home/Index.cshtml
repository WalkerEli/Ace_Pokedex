@{
    ViewData["Title"] = "Home";
}

<div class="p-4 p-md-5 mb-4 rounded-4 bg-light border hero-panel">
    <div class="col-lg-9">
        <h1 class="display-5 fw-bold mb-3">Ace</h1>
        <p class="lead mb-4 text-muted">
            Ace is a Pokemon social platform where you can explore Pokemon, build teams,
            and share ideas with other players.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg" asp-controller="Pokemon" asp-action="Index">browse pokemon</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Teams" asp-action="Create">create team</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Users" asp-action="Me">open profile</a>
            }
            else
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">create account</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Account" asp-action="Login">sign in</a>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h5 fw-semibold">browse pokemon</h2>
                <p class="text-muted mb-0">
                    View detailed Pokemon data including stats, types, abilities, and moves.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h5 fw-semibold">build teams</h2>
                <p class="text-muted mb-0">
                    Create and customize teams with your preferred Pokemon, moves, and strategies.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h5 fw-semibold">share posts</h2>
                <p class="text-muted mb-0">
                    Post content, share ideas, and connect with other users in the community.
                </p>
            </div>
        </div>
    </div>
</div>