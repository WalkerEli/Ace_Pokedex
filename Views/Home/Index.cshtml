@{
    ViewData["Title"] = "Home";
}

<div class="p-4 p-md-5 mb-4 rounded-4 bg-light border hero-panel">
    <div class="col-lg-9">
        <h1 class="display-5 fw-bold mb-3">PokeWeb</h1>
        <p class="lead mb-4">
            Welcome to the first Pokemon Social media Website
        </p>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg" asp-controller="Pokemon" asp-action="Index">browse pokemon</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Teams" asp-action="Create">create team</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Users" asp-action="Me">open profile</a>
            }
            else
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">create account</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Account" asp-action="Login">sign in</a>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">api-first pokemon browsing</h2>
                <p class="mb-0">Pokemon pages are paged from the API instead of bulk-imported into SQLite up front.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">local team persistence</h2>
                <p class="mb-0">Teams store the choices a user made, not a full duplicated copy of every move, ability, and nature.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">account flow ready</h2>
                <p class="mb-0">Users can now register, sign in, sign out, and then create teams and interact with posts under their own account.</p>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-secondary rounded-4 mb-0">
    <strong>demo login:</strong> demo-trainer / demo123!
</div>
