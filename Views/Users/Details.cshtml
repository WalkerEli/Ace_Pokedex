@model TeamAceProject.Models.ViewModels.Users.UserDetailsViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Username;
    Guid? currentUserId = Guid.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var _uid) ? _uid : (Guid?)null;
    bool isOwner = currentUserId.HasValue && currentUserId.Value == Model.Id;
}

<div class="card shadow-sm rounded-4">
    <div class="card-body">
        <h1 class="mb-2">@Model.Username</h1>
        <p class="text-muted">@Model.Email</p>

        <div class="row g-3 mb-3">
            <div class="col-sm-4">
                <div class="border rounded-4 p-3 h-100 d-flex align-items-center gap-3">
                    @if (Model.FavoritePokemonId.HasValue)
                    {
                        <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/@(Model.FavoritePokemonId).gif"
                             alt="@Model.FavoritePokemonName"
                             style="width:64px;height:64px;image-rendering:pixelated;flex-shrink:0;" />
                    }
                    <div>
                        <div class="small text-muted">favorite pokemon</div>
                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(Model.FavoritePokemonName) ? "none" : Model.FavoritePokemonName)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-4">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted">teams</div>
                    <div class="fw-semibold">@Model.TeamCount</div>
                </div>
            </div>

            <div class="col-sm-4">
                <div class="border rounded-4 p-3 h-100">
                    <div class="small text-muted">posts</div>
                    <div class="fw-semibold">@Model.PostCount</div>
                </div>
            </div>
        </div>

        @if (Model.FavoritePokemonId.HasValue && !string.IsNullOrWhiteSpace(Model.FavoritePokemonName))
        {
            <a class="btn btn-outline-primary mb-3"
               asp-controller="Pokemon"
               asp-action="Details"
               asp-route-id="@Model.FavoritePokemonName">
                view favorite pokemon
            </a>
        }

        <hr />

        @if (isOwner)
        {
            <h5 class="mb-2">about me</h5>
            <form asp-controller="Users" asp-action="SetBio" method="post" class="mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@Model.Id" />
                <textarea name="bio" class="form-control mb-2" rows="3"
                          placeholder="write something about yourself..."
                          maxlength="500">@Model.Bio</textarea>
                <button type="submit" class="btn btn-primary btn-sm">save bio</button>
            </form>
        }
        else if (!string.IsNullOrWhiteSpace(Model.Bio))
        {
            <h5 class="mb-2">about</h5>
            <p class="mb-3">@Model.Bio</p>
            <hr />
        }

        <h4 class="mb-3">@Model.Username's teams</h4>

        @if (Model.Teams != null && Model.Teams.Any())
        {
            <ul class="list-group">
                @foreach (var team in Model.Teams)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@team.Name</span>
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-controller="Teams"
                           asp-action="Details"
                           asp-route-id="@team.Id">
                            view
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">no teams created yet</p>
        }
    </div>
</div>