@model TeamAceProject.Models.ViewModels.Pokemon.PokemonListPageViewModel
@{
    ViewData["Title"] = "Pokemon";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Pokemon</h1>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <form asp-controller="Pokemon" asp-action="Index" method="get" class="d-flex gap-2"
              onsubmit="return document.getElementById('pokemon-search').value.trim() !== ''">
            <input type="text" id="pokemon-search" name="query" value="@Model.Query" class="form-control" placeholder="search by name" />
            <button class="btn btn-primary" type="submit">search</button>
        </form>
        @if (!string.IsNullOrWhiteSpace(Model.Query))
        {
            <a asp-controller="Pokemon" asp-action="Index" class="btn btn-outline-secondary">back</a>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    @if (!Model.Pokemon.Any())
    {
        <p class="text-muted">Pokemon was not found.</p>
    }
    @foreach (var pokemon in Model.Pokemon)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm rounded-4 text-center">
                <div class="card-body d-flex flex-column align-items-center">
                    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/@(pokemon.Id).gif"
                         onerror="this.onerror=null;this.src='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/@(pokemon.Id).png'"
                         alt="@pokemon.DisplayName"
                         style="width:64px;height:64px;image-rendering:pixelated;" />
                    <div class="small text-muted">#@pokemon.Id</div>
                    <h2 class="h5 mt-1 mb-3">@pokemon.DisplayName</h2>
                    <a class="btn btn-outline-primary mt-auto w-100" asp-action="Details" asp-route-id="@pokemon.DetailsKey">details</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center">
    <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber - 1)"
       asp-route-pageSize="@Model.PageSize">previous</a>

    <span>page @Model.PageNumber</span>

    <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber + 1)"
       asp-route-pageSize="@Model.PageSize">next</a>
</div>
