@model TeamAceProject.Models.ViewModels.Pokemon.PokemonListPageViewModel
@{
    ViewData["Title"] = "Pokemon";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">pokemon</h1>
        <p class="text-muted mb-0">paged directly from PokeAPI</p>
    </div>
    <form asp-controller="Search" asp-action="Index" method="get" class="d-flex gap-2">
        <input type="text" name="query" class="form-control" placeholder="search by name" />
        <button class="btn btn-primary" type="submit">search</button>
    </form>
</div>

<div class="row g-3 mb-4">
    @foreach (var pokemon in Model.Pokemon)
    {
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm rounded-4">
                <div class="card-body d-flex flex-column">
                    <div class="small text-muted">#@pokemon.Id</div>
                    <h2 class="h5 mt-2">@pokemon.DisplayName</h2>
                    <a class="btn btn-outline-primary mt-auto" asp-action="Details" asp-route-id="@pokemon.DetailsKey">details</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center">
    <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber - 1)"
       asp-route-pageSize="@Model.PageSize">previous</a>

    <span>page @Model.PageNumber</span>

    <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
       asp-action="Index"
       asp-route-page="@(Model.PageNumber + 1)"
       asp-route-pageSize="@Model.PageSize">next</a>
</div>
