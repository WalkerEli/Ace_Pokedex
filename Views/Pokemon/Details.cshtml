@model TeamAceProject.Models.ViewModels.Pokemon.PokemonDetailViewModel
@using TeamAceProject.Infrastructure
@{
    ViewData["Title"] = Model.DisplayName;
    int? currentUserId = User.GetCurrentUserId();
}

<div class="d-flex justify-content-end mb-3">
    <a asp-controller="Pokemon" asp-action="Index" class="btn btn-outline-secondary">back to pokemon</a>
</div>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="small text-muted">#@Model.Id</div>
        <h1 class="mb-1">@Model.DisplayName</h1>
        @if (Model.Types.Any())
        {
            <div class="mb-2">
                @foreach (var type in Model.Types)
                {
                    <span class="badge me-1 pokemon-type-@type.ToLower()">@type</span>
                }
            </div>
        }
        @if (User.Identity?.IsAuthenticated == true && currentUserId.HasValue)
        {
            <form asp-controller="Users" asp-action="FavoritePokemon" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@currentUserId.Value" />
                <input type="hidden" name="pokemonId" value="@Model.Id" />
                <input type="hidden" name="pokemonName" value="@Model.Name" />
                <button type="submit" class="btn btn-primary">set as favorite</button>
            </form>
        }
        else
        {
            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">sign in to favorite</a>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.SpriteUrl))
    {
        <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/versions/generation-v/black-white/animated/@(Model.Id).gif"
             alt="@Model.DisplayName"
             class="pokemon-sprite"
             style="image-rendering:pixelated;"
             onerror="this.src='@Model.SpriteUrl'" />
    }
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4">stats</h2>
                @foreach (var stat in Model.Stats)
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between">
                            <span>@stat.Name</span>
                            <strong>@stat.Value</strong>
                        </div>
                        <div class="progress" role="progressbar" aria-valuenow="@stat.Value" aria-valuemin="0" aria-valuemax="255">
                            <div class="progress-bar" style="width: @(Math.Min(stat.Value, 255) / 255.0 * 100)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4">abilities</h2>
                <ul class="mb-0">
                    @foreach (var ability in Model.Abilities)
                    {
                        <li>@ability</li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4">moves</h2>
                <div class="move-list">
                    @foreach (var move in Model.Moves)
                    {
                        <span class="badge text-bg-light border">@move.DisplayName</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-0">
    <div class="col-lg-6">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4 mb-3">weaknesses</h2>
                @if (Model.Weaknesses.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var (type, mult) in Model.Weaknesses)
                        {
                            <div class="d-flex align-items-center gap-1">
                                <span class="badge pokemon-type-@type.ToLower()">@type</span>
                                <span class="small text-muted">@(mult == 4 ? "4×" : "2×")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">no weaknesses</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4 mb-3">super effective against</h2>
                @if (Model.SuperEffectiveAgainst.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var (type, mult) in Model.SuperEffectiveAgainst)
                        {
                            <div class="d-flex align-items-center gap-1">
                                <span class="badge pokemon-type-@type.ToLower()">@type</span>
                                <span class="small text-muted">@(mult == 4 ? "4×" : "2×")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">no super effective matchups</p>
                }
            </div>
        </div>
    </div>
</div>
